    "    cov       = np.std(norms) / mean_norm * 100\n",
    "    print(f\"{M_h:>6}  {mean_norm:>10.4f}  {var_norm:>12.6f}  {cov:>10.2f}%\")\n",
    "\n",
    "print(\"\\n✅ Variance → 0 as M → ∞: This is Channel Hardening.\")\n",
    "print(\"   Enables simple MRT to approach capacity with massive arrays.\")"
