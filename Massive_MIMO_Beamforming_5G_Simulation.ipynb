    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 5.2 — Run Capacity vs. Number of Antennas Sweep\n",
    "#            (This is the primary Massive MIMO result)\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "print(\"⏳ Running capacity vs. antenna count simulation...\")\n",
    "print(f\"   SNR = {cfg.snr_dB_fixed} dB | K = {cfg.K} users | \"\n",
