    "im2 = ax.imshow(np.real(R), cmap='RdBu_r', vmin=-1, vmax=1, aspect='auto')\n",
    "plt.colorbar(im2, ax=ax, label='Correlation')\n",
    "ax.set_title(f'Spatial Correlation Matrix R\\n(M={M_corr}, Δθ={cfg.angular_spread}°, d={cfg.d_spacing}λ)')\n",
    "ax.set_xlabel('Antenna m')\n",
    "ax.set_ylabel('Antenna n')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('channel_characteristics.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"📊 Channel characteristics plotted.\")"
   ]
