    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 6.1 — Modulation & Demodulation Functions\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def qpsk_modulate(bits):\n",
    "    \"\"\"\n",
    "    Gray-coded QPSK modulation.\n",
    "    Input: array of bits (must be even length)\n",
    "    Output: complex symbols from {±1/√2 ± j/√2}\n",
    "    \"\"\"\n",
    "    bits = np.array(bits).flatten()\n",
    "    if len(bits) % 2 != 0:\n",
    "        bits = np.append(bits, 0)\n",
    "    b_i = bits[0::2]\n",
    "    b_q = bits[1::2]\n",
    "    I = 1.0 - 2.0 * b_i    # Map 0→+1, 1→-1\n",
    "    Q = 1.0 - 2.0 * b_q\n",
    "    return (I + 1j * Q) / np.sqrt(2)\n",
    "\n",
    "\n",
    "def qpsk_demodulate(y):\n",
    "    \"\"\"\n",
    "    QPSK hard decision demodulation.\n",
    "    Output: bit array (2 bits per symbol)\n",
    "    \"\"\"\n",
    "    b_i = (np.real(y) < 0).astype(int)\n",
    "    b_q = (np.imag(y) < 0).astype(int)\n",
    "    bits = np.empty(2 * len(y), dtype=int)\n",
    "    bits[0::2] = b_i\n",
    "    bits[1::2] = b_q\n",
    "    return bits\n",
    "\n",
    "\n",
    "def bpsk_modulate(bits):\n",
    "    return 1.0 - 2.0 * np.array(bits, dtype=float)\n",
    "\n",
    "\n",
    "def bpsk_demodulate(y):\n",
    "    return (np.real(y) < 0).astype(int)\n",
    "\n",
    "\n",
    "def simulate_ber_curve(M, K, cfg, algorithm, rng):\n",
    "    \"\"\"\n",
    "    Simulate BER vs SNR for a given beamforming algorithm.\n",
    "    Uses QPSK modulation, linear (MRC-style) combiner at receiver.\n",
    "    \"\"\"\n",
    "    ber_curve = []\n",
    "    N_bits = cfg.N_bits_per_realization\n",
    "    N_syms = N_bits // 2    # 2 bits/symbol for QPSK\n",
    "\n",
    "    for snr_dB in cfg.snr_dB_range:\n",
    "        snr_linear = 10 ** (snr_dB / 10)\n",
    "        noise_std  = 1.0 / np.sqrt(2 * snr_linear)\n",
    "        total_errors = 0\n",
    "        total_bits   = 0\n",
    "\n",
    "        for _ in range(cfg.N_channel_realizations):\n",
    "            H = generate_channel(M, K, cfg, rng)\n",
    "            W = get_precoder(algorithm, H, snr_linear)   # (M, K) precoder\n",
    "\n",
    "            # Per-user transmission\n",
    "            for k in range(K):\n",
    "                tx_bits  = rng.integers(0, 2, N_bits)\n",
    "                tx_syms  = qpsk_modulate(tx_bits)             # (N_syms,)\n",
    "                w_k      = W[:, k]                            # (M,) beamformer\n",
    "                h_k      = H[:, k]                            # (M,) channel\n",
    "\n",
    "                # Effective scalar channel (after matched combining)\n",
    "                eff_gain = np.dot(h_k.conj(), w_k)            # scalar\n",
    "\n",
    "                # Noise\n",
    "                noise = (noise_std * (rng.standard_normal(N_syms) +\n",
    "                                      1j * rng.standard_normal(N_syms)))\n",
    "                rx_syms  = eff_gain * tx_syms + noise\n",
    "                rx_bits  = qpsk_demodulate(rx_syms)\n",
    "\n",
    "                total_errors += np.sum(tx_bits != rx_bits[:N_bits])\n",
    "                total_bits   += N_bits\n",
    "\n",
    "        ber_curve.append(total_errors / total_bits)\n",
    "\n",
    "    return np.array(ber_curve)\n",
    "\n",
    "\n",
    "print(\"✅ BER simulation functions ready (QPSK).\")"
   ]
  },
