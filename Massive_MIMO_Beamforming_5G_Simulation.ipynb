    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 6.2 — Run BER Simulation\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "print(\"⏳ Running BER simulations (QPSK, Rayleigh channel)...\")\n",
    "print(f\"   M = {cfg.M_default} antennas | K = {cfg.K} users\")\n",
    "print(f\"   {cfg.N_channel_realizations} realizations × {cfg.N_bits_per_realization} bits/user\")\n",
    "\n",
    "ber_results = {}\n",
    "for alg in tqdm(cfg.algorithms, desc='BER per algorithm'):\n",
    "    ber_results[alg] = simulate_ber_curve(cfg.M_default, cfg.K, cfg, alg, rng)\n",
    "\n",
    "# ── Also run BER for different M values (MRT only, to show antenna diversity gain) ──\n",
