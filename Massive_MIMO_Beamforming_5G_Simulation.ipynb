    "---\n",
    "## 📡 Section 3: Channel Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 3.1 — Channel Model Functions\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def generate_rayleigh_channel(M, K, rng):\n",
    "    \"\"\"\n",
    "    Generate i.i.d. Rayleigh fading channel matrix.\n",
    "    H : (M, K) complex Gaussian CN(0, 1/M)\n",
    "    Models rich scattering environment (typical urban NLoS).\n",
    "    \"\"\"\n",
    "    scale = 1.0 / np.sqrt(2 * M)\n",
    "    H = (rng.standard_normal((M, K)) + 1j * rng.standard_normal((M, K))) * scale\n",
    "    return H\n",
    "\n",
    "\n",
    "def generate_rician_channel(M, K, K_factor_dB, rng):\n",
    "    \"\"\"\n",
    "    Generate Rician fading channel (LoS + scattered components).\n",
    "    K_factor: ratio of LoS power to scattered power.\n",
    "    \"\"\"\n",
    "    K_lin = 10 ** (K_factor_dB / 10)\n",
    "    # LoS component (deterministic steering vector to random angles)\n",
    "    theta_los = rng.uniform(-np.pi/3, np.pi/3, K)\n",
    "    a_los = np.exp(1j * np.pi * np.arange(M)[:, None] * np.sin(theta_los)[None, :])\n",
    "    H_los = a_los / np.sqrt(M)\n",
    "\n",
    "    # Scattered component\n",
    "    scale = 1.0 / np.sqrt(2 * M)\n",
    "    H_scattered = (rng.standard_normal((M, K)) + 1j * rng.standard_normal((M, K))) * scale\n",
    "\n",
    "    # Combine LoS + NLoS\n",
    "    H = np.sqrt(K_lin / (K_lin + 1)) * H_los + np.sqrt(1 / (K_lin + 1)) * H_scattered\n",
    "    return H\n",
    "\n",
    "\n",
    "def spatial_correlation_matrix(M, d_spacing, angular_spread_deg):\n",
    "    \"\"\"\n",
    "    Compute Toeplitz spatial correlation matrix using the\n",
    "    Jakes/Clarke model (common in 3GPP channel specifications).\n",
    "    R[m,n] = J0(2π * d * |m-n| * sin(θ_spread))\n",
    "    \"\"\"\n",
    "    from scipy.special import j0  # Bessel function of 1st kind, order 0\n",
    "    sigma_theta = np.deg2rad(angular_spread_deg)\n",
    "    idx = np.arange(M)\n",
    "    diff = np.abs(idx[:, None] - idx[None, :])\n",
    "    R = j0(2 * np.pi * d_spacing * diff * np.sin(sigma_theta))\n",
    "    # Ensure positive semi-definite\n",
    "    eigvals = np.linalg.eigvalsh(R)\n",
    "    if np.min(eigvals) < 0:\n",
    "        R += (-np.min(eigvals) + 1e-8) * np.eye(M)\n",
    "    return R.astype(complex)\n",
    "\n",
    "\n",
    "def generate_spatial_channel(M, K, angular_spread_deg, d_spacing, rng):\n",
    "    \"\"\"\n",
    "    Correlated spatial channel: H = R^(1/2) * H_iid\n",
    "    Models realistic antenna coupling and directional propagation.\n",
    "    \"\"\"\n",
    "    R = spatial_correlation_matrix(M, d_spacing, angular_spread_deg)\n",
    "    # Cholesky decomposition for coloring\n",
    "    try:\n",
    "        L = np.linalg.cholesky(R)\n",
    "    except np.linalg.LinAlgError:\n",
    "        L = np.linalg.cholesky(R + 1e-8 * np.eye(M))\n",
    "\n",
    "    scale = 1.0 / np.sqrt(2 * M)\n",
    "    H_iid = (rng.standard_normal((M, K)) + 1j * rng.standard_normal((M, K))) * scale\n",
    "    H = L @ H_iid\n",
    "    return H\n",
    "\n",
    "\n",
    "def generate_channel(M, K, cfg, rng):\n",
    "    \"\"\"Dispatcher: generate channel according to cfg.channel_model.\"\"\"\n",
    "    if cfg.channel_model == 'rayleigh':\n",
    "        return generate_rayleigh_channel(M, K, rng)\n",
    "    elif cfg.channel_model == 'rician':\n",
    "        return generate_rician_channel(M, K, cfg.K_rician, rng)\n",
    "    elif cfg.channel_model == 'spatial':\n",
    "        return generate_spatial_channel(M, K, cfg.angular_spread, cfg.d_spacing, rng)\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown channel model: {cfg.channel_model}\")\n",
    "\n",
    "\n",
    "print(\"✅ Channel model functions defined.\")\n",
    "print(f\"   Models available: Rayleigh, Rician, Spatially Correlated\")\n",
    "\n",
    "# ── Quick sanity check ────────────────────────────────────────────────────────\n",
    "H_test = generate_channel(cfg.M_default, cfg.K, cfg, rng)\n",
    "print(f\"   Test channel H shape : {H_test.shape}  (M×K = {cfg.M_default}×{cfg.K})\")\n",
    "print(f\"   Mean channel power   : {np.mean(np.abs(H_test)**2):.4f}  (expected ≈ {1/cfg.M_default:.4f})\")"
   ]
