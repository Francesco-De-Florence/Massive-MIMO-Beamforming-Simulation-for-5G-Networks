    "---\n",
    "## 🎯 Section 4: Beamforming Algorithms"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 4.1 — Beamforming Precoder Implementations\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def normalise_precoder(W):\n",
    "    \"\"\"\n",
    "    Normalise precoder so total transmit power = 1.\n",
    "    Per-user power is 1/K.\n",
    "    \"\"\"\n",
    "    norm = np.linalg.norm(W, 'fro')\n",
    "    return W / (norm + 1e-12)\n",
    "\n",
    "\n",
    "def compute_mrt(H):\n",
    "    \"\"\"\n",
    "    Maximum Ratio Transmission (MRT) — Matched Filter Beamforming.\n",
    "\n",
    "    W_MRT = H* / ||H||_F\n",
    "\n",
    "    - Maximises SNR at each user independently.\n",
    "    - Simple, low complexity, but does NOT suppress inter-user interference.\n",
    "    - Optimal only as M → ∞ (channel hardening regime).\n",
    "    \"\"\"\n",
    "    W = np.conj(H)                  # Conjugate beamforming\n",
    "    return normalise_precoder(W)\n",
    "\n",
    "\n",
    "def compute_zf(H):\n",
    "    \"\"\"\n",
    "    Zero-Forcing (ZF) Beamforming — Pseudo-inverse Precoder.\n",
    "\n",
    "    W_ZF = H* (H^T H*)^{-1} / ||W||_F  (right pseudo-inverse)\n",
    "\n",
    "    - Completely eliminates inter-user interference.\n",
    "    - Requires M > K (more antennas than users).\n",
    "    - Noise enhancement problem at low SNR.\n",
    "    \"\"\"\n",
    "    # W = H (H^H H)^{-1}  [standard ZF for downlink]\n",
    "    HH = H.conj().T @ H          # K×K Gram matrix\n",
    "    try:\n",
    "        W = H @ np.linalg.inv(HH)\n",
    "    except np.linalg.LinAlgError:\n",
    "        W = H @ np.linalg.pinv(HH)\n",
    "    return normalise_precoder(W)\n",
    "\n",
    "\n",
    "def compute_mmse(H, snr_linear):\n",
    "    \"\"\"\n",
    "    Minimum Mean Square Error (MMSE) Beamforming — Regularised ZF.\n",
    "\n",
    "    W_MMSE = H (H^H H + (K/SNR) I)^{-1} / ||W||_F\n",
    "\n",
    "    - Balances interference suppression vs. noise amplification.\n",
    "    - Approaches ZF at high SNR, MRT at low SNR.\n",
    "    - Optimal linear precoder for sum-rate maximisation.\n",
    "    - Regularisation parameter: α = K / SNR\n",
    "    \"\"\"\n",
    "    K = H.shape[1]\n",
    "    alpha = K / (snr_linear + 1e-12)   # Regularisation\n",
    "    HH = H.conj().T @ H\n",
    "    W = H @ np.linalg.inv(HH + alpha * np.eye(K))\n",
    "    return normalise_precoder(W)\n",
    "\n",
    "\n",
    "def get_precoder(alg, H, snr_linear=10):\n",
    "    \"\"\"Dispatcher for beamforming algorithm selection.\"\"\"\n",
    "    if alg == 'MRT':\n",
    "        return compute_mrt(H)\n",
    "    elif alg == 'ZF':\n",
    "        return compute_zf(H)\n",
    "    elif alg == 'MMSE':\n",
    "        return compute_mmse(H, snr_linear)\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown algorithm: {alg}\")\n",
    "\n",
    "\n",
    "print(\"✅ Beamforming algorithms implemented:\")\n",
    "for alg, desc in cfg.alg_labels.items():\n",
    "    W = get_precoder(alg, H_test)\n",
    "    print(f\"   [{alg}]  {desc:30s}  →  W shape: {W.shape}, ||W||_F = {np.linalg.norm(W,'fro'):.4f}\")"
   ]
  },
  {
   "cell_type": "code",
