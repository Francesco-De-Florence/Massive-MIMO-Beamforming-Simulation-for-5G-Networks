   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 4.2 — Beampattern Visualisation (ULA Array Response)\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def compute_array_response(angles_rad, M, d_spacing):\n",
    "    \"\"\"\n",
    "    ULA (Uniform Linear Array) steering vector matrix.\n",
    "    a(θ) = [1, e^{j2π d sin(θ)}, ..., e^{j2π(M-1)d sin(θ)}] / sqrt(M)\n",
    "    \"\"\"\n",
    "    m = np.arange(M)[:, None]            # (M, 1)\n",
    "    A = np.exp(1j * 2 * np.pi * d_spacing * m * np.sin(angles_rad)[None, :])  # (M, N_angles)\n",
    "    return A / np.sqrt(M)\n",
    "\n",
    "\n",
    "# ── Setup ─────────────────────────────────────────────────────────────────────\n",
    "M_beam = 64\n",
    "K_beam = 4\n",
    "theta_users = np.deg2rad(np.array([-40, -15, 20, 50]))   # User directions\n",
    "theta_scan  = np.linspace(-np.pi/2, np.pi/2, 720)        # Scan angles\n",
    "\n",
    "# Construct steering-vector-based channel\n",
    "A_users = compute_array_response(theta_users, M_beam, cfg.d_spacing)   # (M, K)\n",
    "H_beam  = A_users + 0.1 * generate_rayleigh_channel(M_beam, K_beam, rng)  # Add scatter\n",
    "\n",
    "# Scan array response\n",
    "A_scan = compute_array_response(theta_scan, M_beam, cfg.d_spacing)     # (M, N_scan)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(17, 5), subplot_kw=dict(polar=False))\n",
    "fig.suptitle(f'Beamforming Patterns — ULA with M={M_beam} Antennas, K={K_beam} Users',\n",
    "             fontsize=14, fontweight='bold')\n",
    "\n",
    "for ax_idx, alg in enumerate(cfg.algorithms):\n",
    "    ax = axes[ax_idx]\n",
    "    W = get_precoder(alg, H_beam, snr_linear=10)\n",
    "\n",
    "    for k in range(K_beam):\n",
    "        w_k = W[:, k]                                        # (M,) beamforming vector\n",
    "        pattern = np.abs(A_scan.conj().T @ w_k) ** 2        # Array gain vs angle\n",
    "        pattern_dB = 10 * np.log10(pattern / np.max(pattern) + 1e-12)\n",
    "        ax.plot(np.rad2deg(theta_scan), pattern_dB,\n",
    "                color=PALETTE[k], alpha=0.85, lw=1.6, label=f'User {k+1}')\n",
    "        # Mark user direction\n",
    "        ax.axvline(np.rad2deg(theta_users[k]), color=PALETTE[k],\n",
    "                   linestyle='--', alpha=0.5, lw=1)\n",
    "\n",
    "    ax.set_xlim(-90, 90)\n",
    "    ax.set_ylim(-40, 2)\n",
    "    ax.set_title(f'{cfg.alg_labels[alg]}')\n",
    "    ax.set_xlabel('Angle θ (degrees)')\n",
    "    ax.set_ylabel('Array Gain (dBi, normalised)' if ax_idx == 0 else '')\n",
