    "---\n",
    "## 📊 Section 5: Spectral Capacity Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 5.1 — Capacity Computation Functions\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "def compute_effective_sinr(H, W, snr_linear):\n",
    "    \"\"\"\n",
    "    Compute per-user effective SINR after precoding.\n",
    "\n",
    "    For user k:\n",
    "      SINR_k = |h_k^H w_k|^2 / (Σ_{j≠k} |h_k^H w_j|^2 + 1/SNR)\n",
    "\n",
    "    Returns array of K SINR values (linear).\n",
    "    \"\"\"\n",
    "    # Effective channel after precoding: G = H^H W  (K×K)\n",
    "    G = H.conj().T @ W         # (K, K)\n",
    "    sinr = np.zeros(H.shape[1])\n",
    "    for k in range(H.shape[1]):\n",
    "        signal_power   = np.abs(G[k, k])**2\n",
    "        interferers    = np.delete(G[k, :], k)\n",
    "        interf_power   = np.sum(np.abs(interferers)**2)\n",
    "        noise_power    = 1.0 / (snr_linear + 1e-12)\n",
    "        sinr[k]        = signal_power / (interf_power + noise_power)\n",
    "    return sinr\n",
    "\n",
    "\n",
    "def compute_ergodic_capacity(M, K, cfg, snr_dB, N_real, algorithm, rng):\n",
    "    \"\"\"\n",
    "    Ergodic sum spectral efficiency via Monte Carlo averaging.\n",
    "    C = E[Σ_k log2(1 + SINR_k)]  [bits/s/Hz]\n",
    "    \"\"\"\n",
    "    snr_linear = 10 ** (snr_dB / 10)\n",
    "    capacity_sum = 0.0\n",
    "    for _ in range(N_real):\n",
    "        H = generate_channel(M, K, cfg, rng)\n",
    "        W = get_precoder(algorithm, H, snr_linear)\n",
    "        sinr = compute_effective_sinr(H, W, snr_linear)\n",
    "        capacity_sum += np.sum(np.log2(1 + sinr))\n",
    "    return capacity_sum / N_real   # Average over realizations\n",
    "\n",
    "\n",
    "def compute_capacity_vs_antennas(M_list, K, cfg, snr_dB, N_real, rng):\n",
    "    \"\"\"\n",
    "    Sweep antenna count M and compute ergodic capacity for all algorithms.\n",
    "    Returns dict: {alg: [capacity_M1, capacity_M2, ...]}\n",
    "    \"\"\"\n",
    "    results = {alg: [] for alg in cfg.algorithms}\n",
    "    for M in tqdm(M_list, desc='Antenna sweep'):\n",
    "        for alg in cfg.algorithms:\n",
    "            C = compute_ergodic_capacity(M, K, cfg, snr_dB, N_real, alg, rng)\n",
    "            results[alg].append(C)\n",
    "    return results\n",
    "\n",
    "\n",
    "print(\"✅ Capacity functions defined.\")\n",
    "\n",
    "# ── Quick single-point check ──────────────────────────────────────────────────\n",
    "for alg in cfg.algorithms:\n",
    "    C_test = compute_ergodic_capacity(cfg.M_default, cfg.K, cfg,\n",
    "                                       cfg.snr_dB_fixed, 100, alg, rng)\n",
    "    print(f\"   [{alg}]  C @ SNR={cfg.snr_dB_fixed}dB, M={cfg.M_default}: {C_test:.2f} bits/s/Hz\")"
   ]
  },
